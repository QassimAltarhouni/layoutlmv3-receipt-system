,\n    \"gst\",\n    \"cash\",\n    \"change\",\n    \"rounding\",\n    \"round off\",\n    \"discount\",\n    \"service charge\",\n    \"paid\",\n    \"payment\",\n    \"tendered\",\n]\nDATE_HINTS = [\"date\", \"time\", \"invoice date\", \"receipt date\"]\n\ndef phrase_hits(text: str, phrases: List[str]) -> int:\n    return sum(1 for phrase in phrases if phrase in text)\n\ndef score_total_line(line_text: str, entity_value: str, y_bottom: float) -> float:\n    norm_line = normalize_for_match(line_text)\n    target_amount = normalize_amount(entity_value)\n    candidates = extract_amount_candidates(line_text)\n    candidate_values = [c[\"canonical\"] for c in candidates]\n\n    score = 0.0\n    if target_amount and target_amount in candidate_values:\n        score += 10.0\n    elif target_amount and target_amount in normalize_compact(line_text):\n        score += 6.0\n\n    score += 2.5 * phrase_hits(norm_line, TOTAL_POSITIVE_HINTS)\n    score -= 2.0 * phrase_hits(norm_line, TOTAL_NEGATIVE_HINTS)\n    score += 1.5 * y_bottom\n\n    if candidates:\n        score += 0.8\n        values = [safe_float_amount(c[\"canonical\"]) for c in candidates]\n        values = [v for v in values if v is not None]\n        if values:\n            score += min(max(values) / 500.0, 1.5)\n\n    return score\n\ndef score_date_line(line_text: str, entity_value: str, y_top: float) -> float:\n    target = normalize_date_like(entity_value)\n    line_norm = normalize_date_like(line_text)\n    candidates = extract_date_candidates(line_text)\n\n    score = 0.0\n    if target and target in line_norm:\n        score += 8.0\n    if any(normalize_date_like(c) == target for c in candidates):\n        score += 10.0\n    if candidates:\n        score += 1.2\n    score += 1.5 * max(0.0, 1.0 - y_top)\n    score += 0.8 * phrase_hits(normalize_for_match(line_text), DATE_HINTS)\n    return score\n\ndef label_lines(ocr_df: pd.DataFrame, entities: Dict[str, str]) -> pd.DataFrame:\n    df = ocr_df.copy()\n    d