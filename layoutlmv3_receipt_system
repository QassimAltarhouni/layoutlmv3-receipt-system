     <td>X51006387660</td>\n      <td>TOTAL</td>\n      <td>5.00</td>\n      <td>4.30</td>\n      <td>5.00</td>\n      <td>4.30</td>\n      <td>False</td>\n    </tr>\n    <tr>\n      <th>691</th>\n      <td>X51006389894</td>\n      <td>TOTAL</td>\n      <td>3.96</td>\n      <td>70.00</td>\n      <td>3.96</td>\n      <td>70.00</td>\n      <td>False</td>\n    </tr>\n    <tr>\n      <th>767</th>\n      <td>X51006466070</td>\n      <td>TOTAL</td>\n      <td>42.90</td>\n      <td>RM42.88</td>\n      <td>42.90</td>\n      <td>42.88</td>\n      <td>False</td>\n    </tr>\n  </tbody>\n</table>\n</div>"},"metadata":{}}],"execution_count":13},{"id":"042baa03","cell_type":"code","source":"# =============================\n# CELL 15: GRADIO DEMO — SROIE + SINGLE/BATCH EXTERNAL IMAGE UPLOAD\n# Fixed batch Gallery PNG output\n# =============================\n\n!pip -q install easyocr gradio\n\nimport os\nimport gc\nimport tempfile\nimport numpy as np\nimport torch\nimport gradio as gr\nimport easyocr\nfrom PIL import Image, ImageDraw\n\n# Close old Gradio demos if they exist\ntry:\n    demo.close()\nexcept Exception:\n    pass\n\ntry:\n    gr.close_all()\nexcept Exception:\n    pass\n\ngc.collect()\n\nocr_reader = easyocr.Reader([\"en\"], gpu=torch.cuda.is_available())\nTEST_DOC_MAP = {doc.doc_id: doc for doc in test_docs}\n\n\ndef normalize_external_box(box, width, height):\n    x0, y0, x1, y1 = box\n    return [\n        max(0, min(1000, int(1000 * x0 / max(1, width)))),\n        max(0, min(1000, int(1000 * y0 / max(1, height)))),\n        max(0, min(1000, int(1000 * x1 / max(1, width)))),\n        max(0, min(1000, int(1000 * y1 / max(1, height)))),\n    ]\n\n\ndef easyocr_to_words_boxes_lines(image):\n    image = image.convert(\"RGB\")\n    image_np = np.array(image)\n    results = ocr_reader.readtext(image_np)\n\n    words = []\n    boxes = []\n    line_ids = []\n    lines = []\n\n    width, height = image.size\n\n    # Sort OCR lines top-to-bottom, then left-to-right\n    sorted_results = []\n\n    for bbox, text, conf in results:\n        xs = [int(float(p[0])) for p in bbox]\n        ys = [int(float(p[1])) for p in bbox]\n        sorted_results.append((min(ys), min(xs), bbox, text, conf))\n\n    sorted_results = sorted(sorted_results, key=lambda x: (x[0], x[1]))\n\n    for line_id, (_, _, bbox, text, conf) in enumerate(sorted_results):\n        text = clean_text(text)\n\n        if not text:\n            continue\n\n        xs = [int(float(p[0])) for p in bbox]\n        ys = [int(float(p[1])) for p in bbox]\n\n        line_box_raw = [\n            int(min(xs)),\n            int(min(ys)),\n            int(max(xs)),\n            int(max(ys)),\n        ]\n\n        line_words, line_word_boxes = split_line_to_words(text, line_box_raw)\n\n        if not line_words:\n            continue\n\n        start_idx = len(words)\n\n        normalized_word_boxes = [\n            normalize_external_box(b, width, height)\n            for b in line_word_boxes\n        ]\n\n        words.extend(line_words)\n        boxes.extend(normalized_word_boxes)\n        line_ids.extend([line_id] * len(line_words))\n\n        lines.append(\n            {\n                \"line_id\": int(line_id),\n                \"text\": str(text),\n                \"box\": normalize_external_box(line_box_raw, width, height),\n                \"entity\": \"O\",\n                \"match_score\": float(conf),\n                \"word_start\": int(start_idx),\n                \"word_end\": int(len(words)),\n            }\n        )\n\n    return words, boxes, line_ids, lines\n\n\ndef decode_external_image_predictions(image, words, boxes):\n    image = image.convert(\"RGB\")\n\n    encoded_raw = processor(\n        images=image,\n        text=words,\n        boxes=boxes,\n        truncation=True,\n        padding=\"max_length\",\n        max_length=cfg.max_length,\n        return_tensors=\"pt\",\n    )\n\n    word_ids = encoded_raw.word_ids(batch_index=0)\n    encoded = {k: v.to(model.device) for k, v in encoded_raw.items()}\n\n    model.eval()\n\n    with torch.no_grad():\n        outputs = model(**encoded)\n\n    token_probs = outputs.logits.softmax(-1).squeeze(0).detach().cpu().numpy()\n\n    word_labels = [\"O\"] * len(words)\n    word_scores = [0.0] * len(words)\n    word_distributions = [\n        np.zeros(len(LABEL_LIST), dtype=np.float32)\n        for _ in words\n    ]\n\n    seen_words = set()\n\n    for token_idx, word_idx in enumerate(word_ids):\n        if word_idx is None or word_idx in seen_words or word_idx >= len(words):\n            continue\n\n        dist = token_probs[token_idx]\n        pred_id = int(np.argmax(dist))\n\n        word_labels[word_idx] = ID2LABEL[pred_id]\n        word_scores[word_idx] = float(dist[pred_id])\n        word_distributions[word_idx] = dist.astype(np.float32)\n\n        seen_words.add(word_idx)\n\n    return {\n        \"labels\": word_labels,\n        \"scores\": word_scores,\n        \"distributions\": word_distributions,\n    }\n\n\ndef draw_prediction(image, words, boxes, labels):\n    image = image.convert(\"RGB\").copy()\n    draw = ImageDraw.Draw(image)\n\n    width, height = image.size\n\n    for word, box, label in zip(words, boxes, labels):\n        if label == \"O\" or \"-\" not in label:\n            continue\n\n        entity = label.split(\"-\", 1)[1]\n        color = ENTITY_COLORS.get(entity, \"purple\")\n\n        x0, y0, x1, y1 = denormalize_box(box, width, height)\n\n        draw.rectangle([x0, y0, x1, y1], outline=color, width=3)\n        draw.text((x0, max(0, y0 - 14)), entity, fill=color)\n\n    return image.convert(\"RGB\")\n\n\ndef json_safe_fields(fields):\n    clean_fields = {}\n\n    for key, value in fields.items():\n        if value is None:\n            clean_fields[str(key)] = \"\"\n        else:\n            clean_fields[str(key)] = str(value)\n\n    return clean_fields\n\n\ndef save_png_for_gradio(image, prefix=\"highlighted\"):\n    image = image.convert(\"RGB\")\n    out_path = tempfile.NamedTemporaryFile(\n        delete=False,\n        suffix=\".png\",\n        prefix=f\"{prefix}_\",\n    ).name\n    image.save(out_path, format=\"PNG\")\n    return out_path\n\n\ndef process_external_receipt_image(image, image_name=\"external_receipt\"):\n    image = image.convert(\"RGB\")\n\n    words, boxes, line_ids, lines = easyocr_to_words_boxes_lines(image)\n\n    if len(words) == 0:\n        return image, {\n            \"image_name\": str(image_name),\n            \"status\": \"failed\",\n            \"error\": \"OCR did not detect readable text.\",\n            \"fields\": {\n                \"COMPANY\": \"\",\n                \"ADDRESS\": \"\",\n                \"DATE\": \"\",\n                \"TOTAL\": \"\",\n            },\n        }\n\n    tmp = tempfile.NamedTemporaryFile(delete=False, suffix=\".png\")\n    image.save(tmp.name, format=\"PNG\")\n\n    external_doc = ReceiptDocument(\n        doc_id=str(image_name),\n        image_path=tmp.name,\n        words=words,\n        boxes=boxes,\n        labels=[\"O\"] * len(words),\n        line_ids=line_ids,\n        lines=lines,\n        ground_truth={},\n    )\n\n    decoded = decode_external_image_predictions(image, words, boxes)\n\n    fields = extract_fields_from_predictions(external_doc, decoded)\n    fields = json_safe_fields(fields)\n\n    highlighted = draw_prediction(\n        image=image,\n        words=words,\n        boxes=boxes,\n        labels=decoded[\"labels\"],\n    )\n\n    result = {\n        \"image_name\": str(image_name),\n        \"status\": \"ok\",\n        \"ocr_words\": int(len(words)),\n        \"fields\": fields,\n    }\n\n    return highlighted, result\n\n\ndef demo_from_sroie(doc_id):\n    if not doc_id:\n        return None, {\"error\": \"Please choose a SROIE receipt.\"}\n\n    doc = TEST_DOC_MAP[doc_id]\n    pred = predict_document(doc)\n\n    with Image.open(doc.image_path) as img:\n        image = img.convert(\"RGB\").copy()\n\n    highlighted = draw_prediction(\n        image=image,\n        words=doc.words,\n        boxes=doc.boxes,\n        labels=pred[\"labels\"],\n    )\n\n    return highlighted, json_safe_fields(pred[\"fields\"])\n\n\ndef demo_from_upload(image):\n    if image is None:\n        return None, {\"error\": \"Please upload a receipt image.\"}\n\n    highlighted, result = process_external_receipt_image(\n        image=image,\n        image_name=\"single_external_upload\",\n    )\n\n    return highlighted.convert(\"RGB\"), result\n\n\ndef get_uploaded_file_path(file_obj):\n    if isinstance(file_obj, str):\n        return file_obj\n\n    if hasattr(file_obj, \"name\"):\n        return file_obj.name\n\n    if isinstance(file_obj, dict):\n        if \"name\" in file_obj:\n            return file_obj[\"name\"]\n        if \"path\" in file_obj:\n            return file_obj[\"path\"]\n\n    raise ValueError(\"Unsupported uploaded file format.\")\n\n\ndef demo_from_multi_upload(files):\n    if not files:\n        return [], {\"error\": \"Please upload one or more receipt images.\"}\n\n    if not isinstance(files, list):\n        files = [files]\n\n    gallery_outputs = []\n    batch_results = []\n\n    for idx, file_obj in enumerate(files, start=1):\n        try:\n            file_path = get_uploaded_file_path(file_obj)\n            image_name = os.path.basename(file_path)\n\n            image = Image.open(file_path).convert(\"RGB\")\n\n            highlighted, result = process_external_receipt_image(\n                image=image,\n                image_name=image_name,\n            )\n\n            # IMPORTANT FIX:\n            # Gradio Gallery can fail with PIL/WebP mode.\n            # So we save each highlighted image as PNG and return the file path.\n            highlighted_path = save_png_for_gradio(\n                highlighted,\n                prefix=f\"receipt_{idx}\",\n            )\n\n            fields = result.get(\"fields\", {})\n            total = fields.get(\"TOTAL\", \"\")\n            date = fields.get(\"DATE\", \"\")\n\n            caption = f\"{idx}. {image_name} | DATE: {date} | TOTAL: {total}\"\n\n            gallery_outputs.append((highlighted_path, caption))\n            batch_results.append(result)\n\n        except Exception as e:\n            batch_results.append(\n                {\n                    \"image_index\": int(idx),\n                    \"image_name\": str(file_obj),\n                    \"status\": \"failed\",\n                    \"error\": str(e),\n                    \"fields\": {\n                        \"COMPANY\": \"\",\n                        \"ADDRESS\": \"\",\n                        \"DATE\": \"\",\n                        \"TOTAL\": \"\",\n                    },\n                }\n            )\n\n    final_json = {\n        \"total_images\": int(len(files)),\n        \"successful_images\": int(\n            sum(1 for r in batch_results if r.get(\"status\") == \"ok\")\n        ),\n        \"failed_images\": int(\n            sum(1 for r in batch_results if r.get(\"status\") != \"ok\")\n        ),\n        \"results\": batch_results,\n    }\n\n    return gallery_outputs, final_json\n\n\nwith gr.Blocks(title=\"Smart Receipt Understanding Demo\") as demo:\n    gr.Markdown(\n        \"\"\"\n        # Smart Receipt Understanding Demo\n\n        **LayoutLMv3 + OCR + Layout-aware Token Classification**\n\n        Extracted fields: **COMPANY, ADDRESS, DATE, TOTAL**\n        \"\"\"\n    )\n\n    with gr.Tab(\"SROIE Test Receipt\"):\n        doc_id = gr.Dropdown(\n            choices=list(TEST_DOC_MAP.keys()),\n            label=\"Choose SROIE test receipt\",\n        )\n\n        btn1 = gr.Button(\"Run prediction\")\n\n        out_img1 = gr.Image(label=\"Highlighted receipt\")\n        out_json1 = gr.JSON(label=\"Extracted fields\")\n\n        btn1.click(\n            fn=demo_from_sroie,\n            inputs=doc_id,\n            outputs=[out_img1, out_json1],\n        )\n\n    with gr.Tab(\"Upload Single Receipt\"):\n        upload_img = gr.Image(\n            type=\"pil\",\n            label=\"Upload one receipt image\",\n        )\n\n        btn2 = gr.Button(\"Run OCR + LayoutLMv3\")\n\n        out_img2 = gr.Image(label=\"Highlighted receipt\")\n        out_json2 = gr.JSON(label=\"Extracted fields\")\n\n        btn2.click(\n            fn=demo_from_upload,\n            inputs=upload_img,\n            outputs=[out_img2, out_json2],\n        )\n\n    with gr.Tab(\"Upload Multiple Receipts\"):\n        upload_files = gr.File(\n            file_count=\"multiple\",\n            file_types=[\".png\", \".jpg\", \".jpeg\", \".webp\"],\n            type=\"filepath\",\n            label=\"Upload multiple receipt images\",\n        )\n\n        btn3 = gr.Button(\"Run Batch OCR + LayoutLMv3\")\n\n        out_gallery = gr.Gallery(\n            label=\"Highlighted receipts\",\n            columns=2,\n            height=\"auto\",\n        )\n\n        out_json3 = gr.JSON(label=\"Batch JSON output\")\n\n        btn3.click(\n            fn=demo_from_multi_upload,\n            inputs=upload_files,\n            outputs=[out_gallery, out_json3],\n        )\n\ndemo.queue()\ndemo.launch(\n    share=True,\n    debug=True,\n    prevent_thread_lock=True,\n    show_error=True,\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T12:17:43.252767Z","iopub.execute_input":"2026-06-28T12:17:43.253074Z","execution_failed":"2026-06-28T19:37:25.955Z"}},"outputs":[{"name":"stdout","text":"* Running on local URL:  http://127.0.0.1:7860\n* Running on public URL: https://17ba8f800af68e47f6.gradio.live\n\nThis share link expires in 1 week. For free permanent hosting and GPU upgrades, run `gradio deploy` from the terminal in the working directory to deploy to Hugging Face Spaces (https://huggingface.co/spaces)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"<div><iframe src=\"https://17ba8f800af68e47f6.gradio.live\" width=\"100%\" height=\"500\" allow=\"autoplay; camera; microphone; clipboard-read; clipboard-write;\" frameborder=\"0\" allowfullscreen></iframe></div>"},"metadata":{}}],"execution_count":null}]}