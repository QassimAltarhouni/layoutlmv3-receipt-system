   self.class_weights = class_weights\n\n    def compute_loss(self, model, inputs, return_outputs=False, num_items_in_batch=None):\n        labels = inputs.get(\"labels\")\n        outputs = model(**inputs)\n\n        if hasattr(outputs, \"logits\"):\n            logits = outputs.logits\n        elif isinstance(outputs, (tuple, list)):\n            logits = outputs[0]\n        elif isinstance(outputs, dict) and \"logits\" in outputs:\n            logits = outputs[\"logits\"]\n        else:\n            raise ValueError(\"Could not find logits in model outputs.\")\n\n        if labels is None:\n            raise ValueError(\"Labels are missing from inputs.\")\n\n        if not torch.is_tensor(labels):\n            labels = torch.tensor(labels, device=logits.device)\n        else:\n            labels = labels.to(logits.device)\n\n        weight = self.class_weights\n        if weight is not None:\n            weight = weight.to(logits.device, dtype=logits.dtype)\n\n        loss_fct = nn.CrossEntropyLoss(\n            weight=weight,\n            ignore_index=-100,\n        )\n\n        loss = loss_fct(\n            logits.reshape(-1, logits.shape[-1]),\n            labels.reshape(-1),\n        )\n\n        return (loss, outputs) if return_outputs else loss\n\nmodel = LayoutLMv3ForTokenClassification.from_pretrained(\n    cfg.model_name,\n    num_labels=len(LABEL_LIST),\n    id2label=ID2LABEL,\n    label2id=LABEL2ID,\n)\n\nprint(\"Trainable parameters:\", f\"{sum(p.numel() for p in model.parameters() if p.requires_grad):,}\")\n\nuse_gpu = torch.cuda.is_available()\nta_params = inspect.signature(TrainingArguments.__init__).parameters\ntrainer_params = inspect.signature(Trainer.__init__).parameters\n\nargs_kwargs = dict(\n    output_dir=str(WORK_DIR / \"checkpoints\"),\n    num_train_epochs=cfg.epochs_gpu if use_gpu else cfg.epochs_cpu,\n    learning_rate=cfg.learning_rate,\n    warmup_ratio=cfg.warmup_ratio,\n    weight_decay=cfg.weight_decay,\n    per_device_train_batch_size=cfg.train_batch_gpu if use_gpu else 1,\n    per_device_eval_batch_size=cfg.eval_batch_gpu if use_gpu else 1,\n    gradient_accumulation_steps=cfg.gradient_accumulation_steps if use_gpu else 4,\n    fp16=use_gpu,\n    dataloader_num_workers=cfg.dataloader_num_workers,\n    eval_accumulation_steps=1,\n    save_total_limit=1,\n    report_to=\"none\",\n    remove_unused_columns=False,\n    save_strategy=\"epoch\",\n    load_best_model_at_end=True,\n    metric_for_best_model=\"f1\",\n    greater_is_better=True,\n    logging_steps=20,\n)\n\nif \"eval_strategy\" in ta_params:\n    args_kwargs[\"eval_strategy\"] = \"epoch\"\nelif \"evaluation_strategy\" in ta_params:\n    args_kwargs[\"evaluation_strategy\"] = \"epoch\"\n\noptional_args = {\n    \"overwrite_output_dir\": True,\n    \"save_safetensors\": True,\n    \"torch_empty_cache_steps\": 50,\n    \"gradient_checkpointing\": False,\n}\n\nfor key, value in optional_args.items():\n    if key in ta_params:\n        args_kwargs[key] = value\n\nargs_kwargs = {key: value for key, value in args_kwargs.items() if key in ta_params}\ntraining_args = TrainingArguments(**args_kwargs)\n\ntrainer_kwargs = dict(\n    model=model,\n    args=training_args,\n    train_dataset=train_dataset,\n    eval_dataset=val_dataset,\n    compute_metrics=compute_metrics,\n    class_weights=class_weights,\n)\n\nif \"processing_class\" in trainer_params:\n    trainer_kwargs[\"processing_class\"] = processor\nelif \"tokenizer\" in trainer_params:\n    trainer_kwargs[\"tokenizer\"] = processor\n\ntrainer = WeightedTokenTrainer(**trainer_kwargs)\n\nprint(\"Effective train batch size:\", training_args.per_device_train_batch_size * training_args.gradient_accumulation_steps)\nprint(\"max_length:\", cfg.max_length)\nprint(\"debug_mode:\", cfg.debug_mode)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T11:54:24.706655Z","iopub.execute_input":"2026-06-28T11:54:24.70712Z","iopub.status.idle":"2026-06-28T11:54:28.882289Z","shell.exe