t = 0\n\n    debug_mode: bool = False\n    debug_train_samples: int = 50\n    debug_eval_samples: int = 10\n\ncfg = CFG()\nset_seed(cfg.seed)\nrandom.seed(cfg.seed)\nnp.random.seed(cfg.seed)\n\nWORK_DIR = Path(cfg.output_dir)\nWORK_DIR.mkdir(parents=True, exist_ok=True)\n\nprint(\"Device:\", \"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(\"Torch:\", torch.__version__)\nprint(\"Output:\", WORK_DIR)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T11:51:44.426161Z","iopub.execute_input":"2026-06-28T11:51:44.426588Z","iopub.status.idle":"2026-06-28T11:52:06.936796Z","shell.execute_reply.started":"2026-06-28T11:51:44.426551Z","shell.execute_reply":"2026-06-28T11:52:06.936106Z"}},"outputs":[{"name":"stdout","text":"Device: cuda\nTorch: 2.10.0+cu128\nOutput: /kaggle/working/layoutlmv3_sroie_fixed_total\n","output_type":"stream"}],"execution_count":2},{"id":"b11b12fa","cell_type":"markdown","source":"## 1. Dataset discovery","metadata":{}},{"id":"9493d378","cell_type":"code","source":"# =============================\n# CELL 3: DATASET DISCOVERY\n# =============================\ndef find_sroie_root() -> Path:\n    candidates = [\n        Path(\"/kaggle/input/sroie-datasetv2/SROIE2019\"),\n        Path(\"/kaggle/input/sroie2019/SROIE2019\"),\n        Path(\"/kaggle/input/sroie-dataset/SROIE2019\"),\n        Path(\"/kaggle/input\"),\n        Path(\"/content\"),\n        Path(\".\"),\n    ]\n    for base in candidates:\n        if not base.exists():\n            continue\n        if (base / \"train\" / \"box\").exists() and (base / \"test\" / \"box\").exists():\n            return base\n        for p in base.rglob(\"*\"):\n            if p.is_dir() and (p / \"train\" / \"box\").exists() and (p / \"test\" / \"box\").exists():\n                return p\n    raise FileNotFoundError(\"SROIE root not found. Set SROIE_ROOT manually.\")\n\nSROIE_ROOT = find_sroie_root()\nTRAIN_DIR = SROIE_ROOT / \"train\"\nTEST_DIR = SROIE_ROOT / \"test\"\n\nprint(\"SROIE root:\", SROIE_ROOT)\nfor split_name, split_dir in [(\"train\", TRAIN_DIR), (\"test\", TEST_DIR)]:\n    print(f\"\\n{split_name.upper()}\")\n    for sub in [\"box\", \"entities\", \"img\"]:\n        folder = split_dir / sub\n        print(f\"{sub:>8}:\", len(list(folder.glob('*'))) if folder.exists() else \"missing\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T11:52:06.93814Z","iopub.execute_input":"2026-06-28T11:52:06.939372Z","iopub.status.idle":"2026-06-28T11:52:07.092446Z","shell.execute_reply.started":"2026-06-28T11:52:06.939347Z","shell.execute_reply":"2026-06-28T11:52:07.091759Z"}},"outputs":[{"name":"stdout","text":"SROIE root: /kaggle/input/datasets/urbikn/sroie-datasetv2/SROIE2019\n\nTRAIN\n     box: 626\nentities: 626\n     img: 626\n\nTEST\n     box: 347\nentities: 347\n     img: 347\n","output_type":"stream"}],"execution_count":3},{"id":"e6adb99f","cell_type":"markdown","source":"## 2. Utilities, parsing, and document structures","metadata":{}},{"id":"17ddfc8d","cell_type":"code","source":"# =============================\n# CELL 4: CONSTANTS + DATA STRUCTURES + TEXT HELPERS\n# =============================\nENTITY_TYPES = [\"COMPANY\", \"ADDRESS\", \"DATE\", \"TOTAL\"]\nLABEL_LIST = [\"O\"] + [f\"{prefix}-{entity}\" for entity in ENTITY_TYPES for prefix in [\"B\", \"I\"]]\nLABEL2ID = {label: idx for idx, label in enumerate(LABEL_LIST)}\nID2LABEL = {idx: label for label, idx in LABEL2ID.items()}\n\n@dataclass\nclass ReceiptDocument:\n    doc_id: str\n    image_path: str\n    words: List[str]\n    boxes: List[List[int]]\n    labels: List[str]\n    line_ids: List[int]\n    lines: List[Dict[str, Any]] = field(default_factory=list)\n    ground_truth: Dict[str, str] = field(default_factory=dict)\n\ndef clean_text(text: str) -> str:\n    text = str(text).replace(\"\\ufeff\", \" \")\n    text = re.sub(r\"\\s+\", \" \", text)\n    return text.strip()\n\ndef normalize_for_match(text: str) -> str:\n    text = clean_text(text).lower()\n    text = re.sub(r\"[^a-z0-9]+\", \" \", text)\n    return re.sub(r\"\\s+\", \" \", text).strip()\n\ndef normalize_compact(text: str) -> str:\n    return re.sub(r\"[^a-z0-9]+\", \"\", clean_text(text).lower())\n\ndef polygon_to_rect(coords: List[int]) -> List[int]:\n    xs = coords[0::2]\n    ys = coords[1::2]\n    return [min(xs), min(ys), max(xs), max(ys)]\n\ndef normalize_box(box: List[int], width: int, height: int) -> List[int]:\n    x0, y0, x1, y1 = box\n    return [\n        max(0, min(1000, int(1000 * x0 / max(1, width)))),\n        max(0, min(1000, int(1000 * y0 / max(1, height)))),\n        max(0, min(1000, int(1000 * x1 / max(1, width)))),\n        max(0, min(1000, int(1000 * y1 / max(1, height)))),\n    ]\n\ndef denormalize_box(box: List[int], width: int, height: int) -> List[int]:\n    x0, y0, x1, y1 = box\n    return [\n        int(x0 * width / 1000),\n        int(y0 * height / 1000),\n        int(x1 * width / 1000),\n        int(y1 * height / 1000),\n    ]\n\ndef normalize_amount(text: str) -> str:\n    text = clean_text(text).upper()\n    text = re.sub(r\"(RM|MYR|USD|SGD|\\$)\", \"\", text)\n    text = text.replace(\" \", \"\")\n    text = re.sub(r\"[^0-9,.\\-]\", \"\", text)\n\n    if not text:\n        return \"\"\n\n    if \",\" in text and \".\" in text:\n        if text.rfind(\".\") > text.rfind(\",\"):\n            text = text.replace(\",\", \"\")\n        else:\n            text = text.replace(\".\", \"\").replace(\",\", \".\")\n    elif \",\" in text:\n        if text.count(\",\") == 1 and len(text.split(\",\")[-1]) in {1, 2}:\n            text = text.replace(\",\", \".\")\n        else:\n            text = text.replace(\",\", \"\")\n\n    try:\n        value = Decimal(text)\n        return f\"{value:.2f}\"\n    except (InvalidOperation, ValueError):\n        return \"\"\n\ndef safe_float_amount(text: str) -> Optional[float]:\n    norm = normalize_amount(text)\n    if not norm:\n        return None\n    try:\n        return float(norm)\n    except ValueError:\n        return None\n\ndef normalize_date_like(text: str) -> str:\n    text = clean_text(text).lower()\n    text = text.replace(\" \", \"\")\n    text = re.sub(r\"[^a-z0-9:/\\-]\", \"\", text)\n    return text\n\nAMOUNT_REGEX = re.compile(r\"(?:RM|MYR|USD|SGD|\\$)?\\s*[-+]?\\d[\\d,]*[.,]\\d{2}\")\nDATE_REGEXES = [\n    re.compile(r\"\\b\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}(?:\\s+\\d{1,2}:\\d{2}(?::\\d{2})?\\s*(?:AM|PM|am|pm)?)?\\b\"),\n    re.compile(r\"\\b\\d{4}[/-]\\d{1,2}[/-]\\d{1,2}(?:\\s+\\d{1,2}:\\d{2}(?::\\d{2})?\\s*(?:AM|PM|am|pm)?)?\\b\"),\n]\n\ndef extract_amount_candidates(text: str) -> List[Dict[str, Any]]:\n    candidates = []\n    seen = set()\n    for m in AMOUNT_REGEX.finditer(clean_text(text)):\n        raw = m.group(0).strip()\n        canonical = normalize_amount(raw)\n        if not canonical or canonical in seen:\n            continue\n        seen.add(canonical)\n        candidates.append({\"raw\": raw, \"canonical\": canonical, \"start\": m.start(), \"end\": m.end()})\n    return candidates\n\ndef extract_date_candidates(text: str) -> List[str]:\n    hits = []\n    seen = set()\n    for pattern in DATE_REGEXES:\n        for m in pattern.finditer(clean_text(text)):\n            value = clean_text(m.group(0))\n            key = normalize_date_like(value)\n            if key and key not in seen:\n                seen.add(key)\n                hits.append(value)\n    return hits\n\ndef token_similarity(a: str, b: str) -> float:\n    a_norm = normalize_for_match(a)\n    b_norm = normalize_for_match(b)\n    if not a_norm or not b_norm:\n        return 0.0\n    if a_norm == b_norm:\n        return 1.0\n    return SequenceMatcher(None, a_norm, b_norm).ratio()\n\ndef token_coverage_score(line_text: str, entity_value: str, min_ratio: float = 0.84) -> float:\n    line_tokens = normalize_for_match(line_text).split()\n    entity_tokens = normalize_for_match(entity_value).split()\n\n    if not line_tokens or not entity_tokens:\n        return 0.0\n\n    matched = 0\n    for token in line_tokens:\n        if any(token_similarity(token, ent_token) >= min_ratio for ent_token in entity_tokens):\n            matched += 1\n\n    coverage_line = matched / max(1, len(line_tokens))\n    coverage_entity = matched / max(1, len(entity_tokens))\n    return max(coverage_line, coverage_entity)\n\ndef general_line_score(line_text: str, entity_value: str) -> float:\n    line_norm = normalize_for_match(line_text)\n    ent_norm = normalize_for_match(entity_value)\n\n    if not line_norm or not ent_norm:\n        return 0.0\n    if ent_norm in line_norm:\n        return 1.0\n    if line_norm in ent_norm:\n        return 0.95\n\n    seq = SequenceMatcher(None, line_norm, ent_norm).ratio()\n    coverage = token_coverage_score(line_text, entity_value)\n    return max(seq, coverage)\n\nprint(\"Labels:\", LABEL_LIST)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T11:52:07.093337Z","iopub.execute_input":"2026-06-28T11:52:07.09371Z","iopub.status.idle":"2026-06-28T11:52:07.16628Z","shell.execute_reply.started":"2026-06-28T11:52:07.09368Z","shell.execute_reply":"2026-06-28T11:52:07.165436Z"}},"outputs":[{"name":"stdout","text":"Labels: ['O', 'B-COMPANY', 'I-COMPANY', 'B-ADDRESS', 'I-ADDRESS', 'B-DATE', 'I-DATE', 'B-TOTAL', 'I-TOTAL']\n","output_type":"stream"}],"execution_count":4},{"id":"e00cb8e7","cell_type":"code","source":"# =============================\n# CELL 5: OCR READERS + ENTITY READERS\n# =============================\ndef read_ocr_lines(box_file: Path) -> pd.DataFrame:\n    rows = []\n    with open(box_file, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n        for line_no, raw_line in enumerate(f.read().splitlines()):\n            if not raw_line.strip():\n                continue\n            parts = raw_line.split(\",\", 8)\n            if len(parts) < 9:\n                continue\n            try:\n                coords = [int(x) for x in parts[:8]]\n            except Val