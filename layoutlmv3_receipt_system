nTest metrics\n{\n  \"test_loss\": 0.13089442253112793,\n  \"test_precision\": 0.611336032388664,\n  \"test_recall\": 0.9798125450612833,\n  \"test_f1\": 0.7529085872576177,\n  \"test_accuracy\": 0.9713500290030517,\n  \"test_runtime\": 66.802,\n  \"test_samples_per_second\": 5.194,\n  \"test_steps_per_second\": 2.605,\n  \"epoch\": 8.0\n}\n","output_type":"stream"}],"execution_count":11},{"id":"81ed0aa3","cell_type":"markdown","source":"## 5. Inference + smart field extraction","metadata":{}},{"id":"ef1dc478","cell_type":"code","source":"# =============================\n# CELL 12: SMART POST-PROCESSING HELPERS\n# =============================\nENTITY_COLORS = {\n    \"COMPANY\": \"orange\",\n    \"ADDRESS\": \"royalblue\",\n    \"DATE\": \"green\",\n    \"TOTAL\": \"red\",\n}\n\ndef decode_word_level_predictions(doc: ReceiptDocument) -> Dict[str, Any]:\n    with Image.open(doc.image_path) as img:\n        image = img.convert(\"RGB\").copy()\n\n    encoded_raw = processor(\n        images=image,\n        text=doc.words,\n        boxes=doc.boxes,\n        truncation=True,\n        padding=\"max_length\",\n        max_length=cfg.max_length,\n        return_tensors=\"pt\",\n    )\n\n    word_ids = encoded_raw.word_ids(batch_index=0)\n    encoded = {k: v.to(model.device) for k, v in encoded_raw.items()}\n\n    model.eval()\n    with torch.no_grad():\n        outputs = model(**encoded)\n\n    token_probs = outputs.logits.softmax(-1).squeeze(0).detach().cpu().numpy()\n    word_labels = [\"O\"] * len(doc.words)\n    word_scores = [0.0] * len(doc.words)\n    word_distributions = [np.zeros(len(LABEL_LIST), dtype=np.float32) for _ in doc.words]\n\n    seen_words = set()\n    for token_idx, word_idx in enumerate(word_ids):\n        if word_idx is None or word_idx in seen_words or word_idx >= len(doc.words):\n            continue\n        dist = token_probs[token_idx]\n        pred_id = int(np.argmax(dist))\n        word_labels[word_idx] = ID2LABEL[pred_id]\n        word_scores[word_idx] = float(dist[pred_id])\n        word_distributions[word_idx] = dist.astype(np.float32)\n        seen_words.add(word_idx)\n\n    return {\n        \"labels\": word_labels,\n        \"scores\": word_scores,\n        \"distributions\": word_distributions,\n    }\n\ndef collect_entity_spans(words: List[str], labels: List[str], scores: List[float]) -> Dict[str, List[Dict[str, Any]]]:\n    spans = defaultdict(list)\n    current_entity = None\n    current_words = []\n    current_scores = []\n    current_start = None\n\n    def flush():\n        nonlocal current_entity, current_words, current_scores, current_start\n        if current_entity and current_words:\n            spans[current_entity].append(\n                {\n                    \"text\": \" \".join(current_words),\n                    \"avg_score\": float(np.mean(current_scores)),\n                    \"start\": current_start,\n                    \"end\": current_start + len(current_words),\n                }\n            )\n        current_entity = None\n        current_words = []\n        current_scores = []\n        current_start = None\n\n    for idx, (word, label, score) in enumerate(zip(words, labels, scores)):\n        if label == \"O\":\n            flush()\n            continue\n\n        prefix, entity = label.split(\"-\", 1)\n        if prefix == \"B\" or entity != current_entity:\n            flush()\n            current_entity = entity\n            current_words = [word]\n            current_scores = [score]\n            current_start = idx\n        else:\n            current_words.append(word)\n            current_scores.append(score)\n\n    flush()\n\n    for entity in spans:\n        spans[entity] = sorted(spans[entity], key=lambda x: (-x[\"avg_score\"], x[\"start\"]))\n    return dict(spans)\n\ndef find_candidate_span_indices(doc: ReceiptDocument, line_meta: Dict[str, Any], candidate_value: str) -> Optional[Tuple[int, int]]:\n    start = line_meta[\"word_start\"]\n    end = line_meta[\"word_end\"]\n    line_words = doc.words[start:end]\n\n    best_local = find_best_amount_span(line_words, candidate_value)\n    if best_local is None:\n        return None\n\n    local_start, local_end = best_local\n    return start + local_start, start + local_end\n\ndef score_total_candidate(\n    doc: ReceiptDocument,\n    line_meta: Dict[str, Any],\n    candidate: Dict[str, Any],\n    word_dists: List[np.ndarray],\n    total_spans: List[Dict[str, Any]],\n    max_receipt_amount: Optional[float],\n) -> float:\n    norm_line = normalize_for_match(line_meta[\"text\"])\n    y_bottom = line_meta[\"box\"][3] / 1000.0\n    start = line_meta[\"word_start\"]\n    end = line_meta[\"word_end\"]\n\n    b_total = LABEL2ID[\"B-TOTAL\"]\n    i_total = LABEL2ID[\"I-TOTAL\"]\n\n    line_total_mass = 0.0\n    for idx in range(start, end):\n        dist = word_dists[idx]\n        line_total_mass += float(dist[b_total] + dist[i_total])\n\n    candidate_score = 0.0\n    candidate_span = find_candidate_span_indices(doc, line_meta, candidate[\"canonical\"])\n    if candidate_span is not None:\n        c_start, c_end = candidate_span\n        mass_values = []\n        for idx in range(c_start, c_end):\n            dist = word_dists[idx]\n            mass_values.append(float(dist[b_total] + dist[i_total]))\n        if mass_values:\n            candidate_score += 4.0 * float(np.mean(mass_values))\n\n    candidate_score += 1.2 * min(3.0, line_total_mass)\n    candidate_score += 2.5 * phrase_hits(norm_line, TOTAL_POSITIVE_HINTS)\n    candidate_score -= 2.0 * phrase_hits(norm_line, TOTAL_NEGATIVE_HINTS)\n    candidate_score += 1.5 * y_bottom\n\n    amount_value = safe_float_amount(candidate[\"canonical\"])\n    if amount_value is not None and max_receipt_amount not in (None, 0):\n        candidate_score += min(amount_value / max_receipt_amount, 1.0)\n\n    if total_spans:\n        top_span_amount = normalize_amount(total_spans[0][\"text\"])\n        if top_span_amount and top_span_amount == candidate[\"canonical\"]:\n            candidate_score += 3.0\n\n    if norm_line.startswith(\"total\") or \"grand total\" in norm_line or \"amount due\" in norm_line:\n        candidate_score += 1.5\n\n    return candidate_score\n\ndef smart_extract_total(doc: ReceiptDocument, spans: Dict[str, List[Dict[str, Any]]], word_dists: List[np.ndarray]) -> str:\n    total_spans = spans.get(\"TOTAL\", [])\n    all_candidates = []\n    all_amounts = []\n\n    for line_meta in doc.lines:\n        line_candidates = extract_amount_candidates(line_meta[\"text\"])\n        for candidate in line_candidates:\n            value = safe_float_amount(candidate[\"canonical\"])\n            if value is not None:\n                all_amounts.append(value)\n            all_candidates.append((line_meta, candidate))\n\n    max_receipt_amount = max(all_amounts) if all_amounts else None\n\n    scored = []\n    for line_meta, candidate in all_candidates:\n        score = score_total_candidate(doc, line_meta, candidate, word_dists, total_spans, max_receipt_amount)\n        scored.append((score, candidate[\"canonical\"], line_meta[\"text\"]))\n\n    scored.sort(reverse=True, key=lambda x: x[0])\n\n    if scored and scored[0][0] >= 2.2:\n        return scored[0][1]\n\n    if total_spans:\n        fallback = normalize_amount(total_spans[0][\"text\"])\n        if fallback:\n            return fallback\n\n    return \"\"\n\ndef smart_extract_date(doc: ReceiptDocument, spans: Dict[str, List[Dict[str, Any]]], word_dists: List[np.ndarray]) -> str:\n    date_spans = spans.get(\"DATE\", [])\n    if date_spans:\n        return clean_text(date_spans[0][\"text\"])\n\n    b_date = LABEL2ID[\"B-DATE\"]\n    i_date = LABEL2ID[\"I-DATE\"]\n\n    best = (\"\", float(\"-inf\"))\n    for line_meta in doc.lines:\n        candidates = extract_date_candidates(line_meta[\"text\"])\n        if not candidates:\n            continue\n\n        start = line_meta[\"word_start\"]\n        end = line_meta[\"word_end\"]\n        score = 0.0\n        for idx in range(start, end):\n            dist = word_dists[idx]\n            score += float(dist[b_date] + dist[i_date])\n\n        score += 0.8 * phrase_hits(normalize_for_match(line_meta[\"text\"]), DATE_HINTS)\n        score += 1.0 * (1.0 - (line_meta[\"box\"][1] / 1000.0))\n\n        if score > best[1]:\n            best = (clean_text(candidates[0]), score)\n\n    return best[0]\n\ndef smart_extract_company(doc: ReceiptDocument, spans: Dict[str, List[Dict[str, Any]]]) -> str:\n    company_spans = spans.get(\"COMPANY\", [])\n    if company_spans:\n        return clean_text(company_spans[0][\"text\"])\n\n    best_text = \"\"\n    best_score = float(\"-inf\")\n    for line_meta in doc.lines[:8]:\n        text = clean_text(line_meta[\"text\"])\n        if not text:\n            continue\n        score = 0.0\n        score += 1.2 if text.upper() == text else 0.0\n        score += 1.0 - (line_meta[\"box\"][1] / 1000.0)\n        if len(text) <= 4:\n            score -= 1.5\n        if any(ch.isdigit() for ch in text):\n            score -= 0.5\n        if score > best_score:\n            best_score = score\n            best_text = text\n\n    return best_text\n\ndef smart_extract_address(doc: ReceiptDocument, spans: Dict[str, List[Dict[str, Any]]]) -> str:\n    address_spans = spans.get(\"ADDRESS\", [])\n    if address_spans:\n        ordered = sorted(address_spans, key=lambda x: x[\"start\"])\n        merged = []\n        for span in ordered[:4]:\n            text = clean_text(span[\"text\"])\n            if text and text not in merged:\n                merged.append(text)\n        return \", \".join(merged)\n\n    return \"\"\n\ndef extract_fields_from_predictions(doc: ReceiptDocument, decoded: Dict[str, Any]) -> Dict[str, str]:\n    spans = collect_entity_spans(doc.words, decoded[\"labels\"], decoded[\"scores\"])\n    fields = {\n        \"COMPANY\": smart_extract_company(doc, spans),\n        \"ADDRESS\": smart_extract_address(doc, spans),\n        \"DATE\": smart_extract_date(doc, spans, decoded[\"distributions\"]),\n        \"TOTAL\": smart_extract_total(doc, spans, decoded[\"distributions\"]),\n    }\n    return {k: clean_text(v) for k, v in fields.items()}","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T12:16:37.175881Z","iopub.execute_input":"2026-06-28T12:16:37.17617Z","iopub.status.idle":"2026-06-28T12:16:37.203207Z","shell.execute_reply.started":"2026-06-28T12:16:37.176144Z","shell.execute_reply":"2026-06-28T12:16:37.202585Z"}},"outputs":[],"execution_count":12},{"id":"c2b4fe26","cell_type":"code","source":"# =============================\n# CELL 13: PREDICTION + FIELD-LEVEL EVALUATION + VISUALIZATION\n# =============================\ndef predict_document(doc: ReceiptDocument) -> Dict[str, Any]:\n    decoded = decode_word_level_predictions(doc)\n    fields = extract_fields_from_predictions(doc, decoded)\n    return {\n        \"doc_id\": doc.doc_id,\n        \"words\": doc.words,\n        \"boxes\": doc.boxes,\n        \"labels\": decoded[\"labels\"],\n        \"scores\": decoded[\"scores\"],\n        \"fields\": fields,\n    }\n\ndef normalize_field_value(field_name: str, value: str) -> str:\n    if field_name == \"TOTAL\":\n        return normalize_amount(value)\n    if field_name == \"DATE\":\n        return normalize_date_like(value)\n    return normalize_for_match(value)\n\ndef evaluate_field_extraction(\n    docs: List[ReceiptDocument],\n    sample_limit: Optional[int] = None,\n) -> pd.DataFrame:\n    rows = []\n    iterable = docs if sample_limit is None else docs[:sample_limit]\n\n    for doc in iterable:\n        pred = predict_document(doc)\n        for field_name in ENTITY_TYPES:\n            pred_value = pred[\"fields\"].get(field_name, \"\")\n            true_value = doc.ground_truth.get(field_name, \"\")\n            rows.append(\n                {\n                    \"doc_id\": doc.doc_id,\n                    \"field\": field_name,\n                    \"pred\": pred_value,\n                    \"true\": true_value,\n                    \"pred_norm\": normalize_field_value(field_name, pred_value),\n                    \"true_norm\": normalize_field_value(field_name, true_value),\n                }\n            )\n\n    result = pd.DataFrame(rows)\n    result[\"exact_match\"] = result[\"pred_norm\"] == result[\"true_norm\"]\n    return result\n\ndef visualize_prediction(\n    doc: ReceiptDocument,\n    prediction: Optional[Dict[str, Any]] = None,\n    max_words: int = 512,\n):\n    if prediction is None:\n        prediction = predict_document(doc)\n\n    try:\n        from PIL import ImageDraw\n        image_draw_available = True\n    except Exception as e:\n        image_draw_available = False\n        print(f\"Visualization fallback: ImageDraw unavailable -> {e}\")\n\n    with Image.open(doc.image_path) as img:\n        image = img.convert(\"RGB\").copy()\n\n    width, height = image.size\n\n    if image_draw_available:\n        draw = ImageDraw.Draw(image)\n\n        for word, box, label in zip(\n            doc.words[:max_words],\n            doc.boxes[:max_words],\n            prediction[\"labels\"][:max_words],\n        ):\n            if label == \"O\":\n                continue\n            entity = label.split(\"-\", 1)[1]\n            color = ENTITY_COLORS.get(entity, \"purple\")\n            x0, y0, x1, y1 = denormalize_box(box, width, height)\n            draw.rectangle([x0, y0, x1, y1], outline=color, width=3)\n            draw.text((x0, max(0, y0 - 12)), entity, fill=color)\n    else:\n        print(\"Skipping box drawing, showing the image only.\")\n\n    plt.figure(figsize=(10, 14))\n    plt.imshow(image)\n    plt.axis(\"off\")\n    plt.title(f\"Prediction: {doc.doc_id}\")\n    plt.show()\n\nsample_prediction = predict_document(test_docs[0])\nprint(json.dumps(sample_prediction[\"fields\"], indent=2, ensure_ascii=False))\nvisualize_prediction(test_docs[0], sample_prediction)\n\nfield_eval_df = evaluate_field_extraction(test_docs)\nfield_summary = (\n    field_eval_df.groupby(\"field\")[\"exact_match\"]\n    .agg([\"mean\", \"count\"])\n    .rename(columns={\"mean\": \"exact_match_rate\"})\n    .sort_index()\n)\ndisplay(field_summary)\n\ntotal_errors = field_eval_df[\n    (field_eval_df[\"field\"] == \"TOTAL\") & (~field_eval_df[\"exact_match\"])\n].copy()\ndisplay(total_errors.head(20))\n\nfield_eval_df.to_csv(WORK_DIR / \"field_level_results.csv\", index=False, encoding=\"utf-8\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T12:16:37.204112Z","iopub.execute_input":"2026-06-28T12:16:37.204351Z","iopub.status.idle":"2026-06-28T12:17:43.25171Z","shell.execute_reply.started":"2026-06-28T12:16:37.204332Z","shell.execute_reply":"2026-06-28T12:17:43.251175Z"}},"outputs":[{"name":"stdout","text":"{\n  \"COMPANY\": \"OJC MARKETING SDN BHD\",\n  \"ADDRESS\": \"NO 2 & 4, JALAN BAYU 4,\",\n  \"DATE\": \"15/01/2019\",\n  \"TOTAL\": \"193.00\"\n}\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1000x1400 with 1 Axes>","image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"         exact_match_rate  count\nfield                           \nADDRESS          0.028818    347\nCOMPANY          0.639769    347\nDATE             0.855908    347\nTOTAL            0.896254    347","text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>exact_match_rate</th>\n      <th>count</th>\n    </tr>\n    <tr>\n      <th>field</th>\n      <th></th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>ADDRESS</th>\n      <td>0.028818</td>\n      <td>34